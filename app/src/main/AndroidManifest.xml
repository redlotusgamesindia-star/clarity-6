<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        Privacy posture (the manifest IS the policy):
        - NO INTERNET permission, ever. Offline-only is structural, not a promise.
        - POST_NOTIFICATIONS: local habit reminders only (runtime-gated, 13+).
        - RECEIVE_BOOT_COMPLETED: re-arms reminder alarms after reboot.
        Nothing here can move data off the device. (ARCHITECTURE.md §14, §18)
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".ClarityApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Clarity"
        tools:targetApi="35">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Clarity.Splash"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Reminder alarms fire here; reads the habit fresh, posts, re-chains. -->
        <receiver
            android:name=".data.notifications.HabitReminderReceiver"
            android:exported="false" />

        <!-- Alarms don't survive reboot; this re-arms every enabled reminder. -->
        <receiver
            android:name=".data.notifications.BootCompletedReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
