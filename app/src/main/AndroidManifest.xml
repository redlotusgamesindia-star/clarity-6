<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        Privacy posture (the manifest IS the policy) — updated for banner
        ads (ARCHITECTURE.md §23):

        Until now this comment said "NO INTERNET permission, ever." That was
        true through Phase E and is no longer true starting here — this is
        the one deliberate, discussed exception, not an oversight:

        - INTERNET / ACCESS_NETWORK_STATE / AD_ID: required by Google
          Mobile Ads (AdMob) to serve a small banner ad, and by the User
          Messaging Platform (UMP) SDK to gather consent before doing so.
        - Ads NEVER appear during onboarding, breathing, guided grounding/
          muscle exercises, the relapse recovery flow, the SOS toolkit, any
          journal/thought-record/gratitude editor, or for premium users.
          They are allow-listed onto Home, Journey, and the Journal list
          only — see domain/ads/AdScreen.kt, whose closed enum membership
          IS the allow-list (fail-closed: a screen with no AdScreen value
          simply cannot show ads, rather than needing to be excluded).
        - Consent is gathered via UMP before the ads SDK initializes at all
          (ads/AdsManager.kt). UMP requires a reachable privacy-options
          entry point; this app has no Settings screen to put one in, so
          a small "Privacy & ad choices" link lives on Home instead,
          visible only when UMP reports one is actually required.
        - POST_NOTIFICATIONS: local habit reminders only (runtime-gated, 13+).
        - RECEIVE_BOOT_COMPLETED: re-arms reminder alarms after reboot.

        Nothing else moves data off the device: the encrypted recovery
        database, journal, and thought records are never touched by any of
        this and stay exactly as private as before.
    -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="com.google.android.gms.permission.AD_ID" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".ClarityApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Clarity"
        tools:targetApi="35">

        <!-- Production AdMob App ID — constant across build types; only the
             banner AD UNIT id differs by build type (see AdsManager). -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-9035742345664521~6617275584" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Clarity.Splash"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Reminder alarms fire here; reads the habit fresh, posts, re-chains. -->
        <receiver
            android:name=".data.notifications.HabitReminderReceiver"
            android:exported="false" />

        <!--
            Alarms don't survive reboot; this re-arms every enabled reminder
            (and, as of Phase D, the widget's daily refresh alarm too).
            exported="false" is intentional and correct here, not an
            oversight: BOOT_COMPLETED is a protected system broadcast, so the
            system can deliver it to a non-exported receiver regardless —
            exported only gates whether OTHER APPS could also trigger this
            receiver, which they should never be able to. (ARCHITECTURE.md §20)
        -->
        <receiver
            android:name=".data.notifications.BootCompletedReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Daily just-after-midnight widget refresh; self-chains, see WidgetRefreshScheduler. -->
        <receiver
            android:name=".data.widget.WidgetRefreshReceiver"
            android:exported="false" />

        <!--
            The home-screen widget. exported="true" here (unlike the
            receivers above) because the launcher/AppWidgetHost — a
            different app/process — is what delivers APPWIDGET_UPDATE,
            matching Google's own Glance widget sample exactly.
        -->
        <receiver
            android:name=".widget.ClarityWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/clarity_widget_info" />
        </receiver>
    </application>
</manifest>
