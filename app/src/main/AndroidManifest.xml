<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        Privacy posture (the manifest IS the policy):
        - NO INTERNET permission, ever. Offline-only is structural, not a promise.
        - POST_NOTIFICATIONS: local habit reminders only (runtime-gated, 13+).
        - RECEIVE_BOOT_COMPLETED: re-arms reminder alarms after reboot.
        Nothing here can move data off the device. (ARCHITECTURE.md §14, §18)
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".ClarityApp"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="false"
        android:enableOnBackInvokedCallback="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Clarity"
        tools:targetApi="35">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Clarity.Splash"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Reminder alarms fire here; reads the habit fresh, posts, re-chains. -->
        <receiver
            android:name=".data.notifications.HabitReminderReceiver"
            android:exported="false" />

        <!--
            Alarms don't survive reboot; this re-arms every enabled reminder
            (and, as of Phase D, the widget's daily refresh alarm too).
            exported="false" is intentional and correct here, not an
            oversight: BOOT_COMPLETED is a protected system broadcast, so the
            system can deliver it to a non-exported receiver regardless —
            exported only gates whether OTHER APPS could also trigger this
            receiver, which they should never be able to. (ARCHITECTURE.md §20)
        -->
        <receiver
            android:name=".data.notifications.BootCompletedReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Daily just-after-midnight widget refresh; self-chains, see WidgetRefreshScheduler. -->
        <receiver
            android:name=".data.widget.WidgetRefreshReceiver"
            android:exported="false" />

        <!--
            The home-screen widget. exported="true" here (unlike the
            receivers above) because the launcher/AppWidgetHost — a
            different app/process — is what delivers APPWIDGET_UPDATE,
            matching Google's own Glance widget sample exactly.
        -->
        <receiver
            android:name=".widget.ClarityWidgetReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/clarity_widget_info" />
        </receiver>
    </application>
</manifest>
