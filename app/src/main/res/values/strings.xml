    <!-- Plan items (code -> copy; DB stores codes only) -->
    <string name="plan_daily_checkin_title">Daily check-in</string>
    <string name="plan_daily_checkin_desc">Two minutes each day to log mood, urges, and wins. Consistency beats intensity.</string>
    <string name="plan_learn_urge_toolkit_title">Learn the urge toolkit</string>
    <string name="plan_learn_urge_toolkit_desc">Practice the breathing and delay tools once while calm, so they\'re familiar when it counts.</string>
    <string name="plan_define_your_why_title">Write down your why</string>
    <string name="plan_define_your_why_desc">Turn the reasons you chose into one sentence you\'ll see when it matters most.</string>
    <string name="plan_first_milestone_focus_title">Focus on your first milestone</string>
    <string name="plan_first_milestone_focus_desc">One clear target to start. Reaching it rewires what feels possible.</string>
    <string name="plan_abstinence_identity_title">Build the identity, not just the streak</string>
    <string name="plan_abstinence_identity_desc">You\'re not \'trying to stop\' — you\'re becoming someone who doesn\'t watch. Small daily proof compounds.</string>
    <string name="plan_reboot_90_frame_title">Frame the 90-day reboot</string>
    <string name="plan_reboot_90_frame_desc">Ninety days gives your brain\'s reward system a genuine reset. Week by week, not all at once.</string>
    <string name="plan_reduction_ladder_title">Set your reduction ladder</string>
    <string name="plan_reduction_ladder_desc">Define clear step-downs — fewer days, tighter limits — so progress is measurable, not vague.</string>
    <string name="plan_high_risk_moment_map_title">Map your high-risk moments</string>
    <string name="plan_high_risk_moment_map_desc">Daily habits hide in routines. Spot the exact times and places, then plan around them.</string>
    <string name="plan_device_friction_setup_title">Add friction to your devices</string>
    <string name="plan_device_friction_setup_desc">Blockers, app limits, grayscale after dark — make the easy path the healthy one.</string>
    <string name="plan_stress_reset_breathing_title">Use breathing as your stress reset</string>
    <string name="plan_stress_reset_breathing_desc">When stress spikes, ninety seconds of slow breathing beats willpower. It\'s built into your SOS button.</string>
    <string name="plan_boredom_replacement_list_title">Build a boredom replacement list</string>
    <string name="plan_boredom_replacement_list_desc">Five go-to activities you can start in under a minute. Boredom needs an answer ready.</string>
    <string name="plan_connection_plan_title">Make a connection plan</string>
    <string name="plan_connection_plan_desc">Loneliness is the trigger, so connection is the tool: one real interaction a day, even a message.</string>
    <string name="plan_fatigue_energy_audit_title">Run an energy audit</string>
    <string name="plan_fatigue_energy_audit_desc">Track when you\'re most drained this week. Fatigue urges are usually a sleep problem in disguise.</string>
    <string name="plan_social_media_hygiene_title">Clean up your feeds</string>
    <string name="plan_social_media_hygiene_desc">Unfollow and mute the accounts that start the spiral. The urge often begins three scrolls earlier.</string>
    <string name="plan_emotion_journaling_title">Name the feeling first</string>
    <string name="plan_emotion_journaling_desc">Before acting on an urge, write one line about what you\'re actually feeling. Naming it breaks the loop.</string>
    <string name="plan_if_then_plans_title">Write if-then plans</string>
    <string name="plan_if_then_plans_desc">\'If an urge hits, then I open the toolkit.\' Deciding in advance removes the hardest step.</string>
    <string name="plan_late_night_device_curfew_title">Set a device curfew</string>
    <string name="plan_late_night_device_curfew_desc">Phone out of the bedroom, or locked down after a set hour. Late-night urges lose their easiest doorway.</string>
    <string name="plan_morning_launch_routine_title">Design a morning launch</string>
    <string name="plan_morning_launch_routine_desc">Feet on the floor, phone stays down for the first 20 minutes. Momentum before temptation.</string>
    <string name="plan_evening_transition_ritual_title">Create an evening transition</string>
    <string name="plan_evening_transition_ritual_desc">A repeatable wind-down — shower, walk, music — that carries you through the risky hours.</string>
    <string name="plan_afternoon_reset_walk_title">Take the afternoon reset</string>
    <string name="plan_afternoon_reset_walk_desc">A short walk or stretch at your danger hour. Change your state before the urge chooses for you.</string>
    <string name="plan_wind_down_routine_title">Build a wind-down routine</string>
    <string name="plan_wind_down_routine_desc">Thirty screen-light minutes before bed. Calmer nights mean fewer late-night battles.</string>
    <string name="plan_sleep_anchor_time_title">Anchor your sleep time</string>
    <string name="plan_sleep_anchor_time_desc">Pick one consistent lights-out time. A stable schedule quietly removes dozens of risky hours a week.</string>
    <string name="plan_start_tiny_commitment_title">Start tiny on purpose</string>
    <string name="plan_start_tiny_commitment_desc">Motivation grows from evidence. Commit to the check-in and one tool — nothing more yet.</string>
    <string name="plan_channel_momentum_title">Channel this momentum</string>
    <string name="plan_channel_momentum_desc">You\'re starting strong — bank it. Set up your environment and routines this week while it\'s easy.</string>
    <string name="plan_streak_pattern_review_title">Review what ended past streaks</string>
    <string name="plan_streak_pattern_review_desc">You\'ve gone long stretches before. Write down what happened at the end — that\'s where your plan needs armor.</string>

